---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { postFilter } from "@/utils/postFilter";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = (await getCollection("posts")).filter(postFilter);
const sortedPosts = getSortedPosts(posts);
const recentEssays = sortedPosts
  .filter(({ data }) => data.kind === "essay")
  .slice(0, postsConfig.perIndex);
const recentNotes = sortedPosts
  .filter(({ data }) => data.kind === "note")
  .slice(0, postsConfig.perIndex);

const seriesList = await getCollection("series");
const seriesWithCount = seriesList
  .map(s => ({
    ...s,
    chapterCount: posts.filter(p => p.data.series?.id === s.id).length,
  }))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const statusLabel: Record<string, string> = {
  ongoing: "Ongoing",
  complete: "Complete",
  planned: "Planned",
};

const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section
      id="hero"
      class="border-border flex flex-col-reverse items-start gap-6 border-b pt-8 pb-6 sm:flex-row sm:items-center sm:gap-8"
    >
      <div class="flex-1">
        <h1 class="my-4 inline-block text-4xl font-bold sm:my-4 sm:text-5xl">
          Hi, I'm Luisa.
        </h1>
        <p>
          I'm an independent advisor working on agentic AI systems and how
          to make them secure by design. I build tools at
          <LinkButton
            class="hover:text-accent underline decoration-dashed underline-offset-4"
            href="https://liwala.dev"
          >
            liwala.dev
          </LinkButton>, and write about the architectural decisions behind
          my work here and on my Substack,
          <LinkButton
            class="hover:text-accent underline decoration-dashed underline-offset-4"
            href="https://herdingagents.substack.com"
          >
            Herding Agents
          </LinkButton>.
        </p>
        {
          socials.length > 0 && (
            <div class="mt-4 flex max-sm:flex-col sm:items-center">
              <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">
                {t.home.socialLinks}:
              </div>
              <Socials />
            </div>
          )
        }
      </div>
      <img
        src="/avatar.jpg"
        alt="Luisa Lima"
        width="160"
        height="160"
        class="ring-border size-32 flex-none rounded-full object-cover ring-1 sm:size-40"
      />
    </section>

    <section id="recent-essays" class="border-border border-b pt-12 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">Recent essays</h2>
      {
        recentEssays.length === 0 ? (
          <p class="text-muted-foreground mt-2 italic">No essays yet.</p>
        ) : (
          <ul>
            {recentEssays.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        )
      }
      <div class="mt-4">
        <LinkButton href={getRelativeLocaleUrl(locale, "essays")}>
          All essays
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
    </section>

    <section id="recent-notes" class="border-border border-b pt-12 pb-6">
      <h2 class="text-2xl font-semibold tracking-wide">Recent notes</h2>
      {
        recentNotes.length === 0 ? (
          <p class="text-muted-foreground mt-2 italic">No notes yet.</p>
        ) : (
          <ul>
            {recentNotes.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        )
      }
      <div class="mt-4">
        <LinkButton href={getRelativeLocaleUrl(locale, "notes")}>
          All notes
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
    </section>

    {
      seriesWithCount.length > 0 && (
        <section id="home-series" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Series</h2>
          <ul class="mt-4 space-y-6">
            {seriesWithCount.map(s => (
              <li>
                <a
                  href={`/series/${s.id}/`}
                  class="hover:text-accent text-lg font-medium"
                >
                  {s.data.title}
                </a>
                <div class="text-muted-foreground text-sm">
                  {statusLabel[s.data.status] ?? s.data.status} · {s.chapterCount}{" "}
                  {s.chapterCount === 1 ? "chapter" : "chapters"}
                </div>
                <p class="mt-1">{s.data.description}</p>
              </li>
            ))}
          </ul>
          <div class="mt-6">
            <LinkButton href={getRelativeLocaleUrl(locale, "series")}>
              All series
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
