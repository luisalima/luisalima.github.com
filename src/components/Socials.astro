---
import config from "@/config";
import LinkButton from "./LinkButton.astro";

const { site, socials } = config;

const icons = import.meta.glob<{
  default: (_props: Record<string, unknown>) => unknown;
}>("/src/assets/icons/socials/*.svg");

// Per-brand color classes applied to the icon. Tailwind 4 arbitrary
// colors keep brand hues in light mode; dark-mode overrides ensure
// dark-on-dark icons stay visible.
const colorClass: Record<string, string> = {
  github: "text-[#181717] dark:text-white",
  linkedin: "text-[#0A66C2]",
  substack: "text-[#FF6719]",
  mail: "text-[#EA4335]",
  rss: "text-[#F26522]",
  x: "text-black dark:text-white",
};

const items = await Promise.all(
  socials.map(async ({ name, url, linkTitle }) => {
    const mod = await icons[`/src/assets/icons/socials/${name}.svg`]?.();
    const Icon = mod?.default;
    const isMail = url.startsWith("mailto:") || name === "mail";
    const isRss = name === "rss";
    const title =
      linkTitle ??
      (isMail
        ? `Send an email to ${site.title}`
        : isRss
          ? `${site.title} RSS feed`
          : `${site.title} on ${name.charAt(0).toUpperCase() + name.slice(1)}`);
    const tint = colorClass[name] ?? "";
    return { url, title, Icon, tint };
  })
);
---

<div class="flex flex-wrap items-center gap-1">
  {
    items.map(({ url, title, Icon, tint }) =>
      Icon ? (
        <LinkButton href={url} class="p-2 hover:rotate-6 sm:p-1" title={title}>
          <Icon
            class:list={[
              "inline-block size-6 scale-125 fill-transparent stroke-current stroke-2 opacity-90 group-hover:fill-transparent sm:scale-110",
              tint,
            ]}
          />
          <span class="sr-only">{title}</span>
        </LinkButton>
      ) : null
    )
  }
</div>
